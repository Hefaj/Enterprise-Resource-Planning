{
  "name": "task-management",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "frontend/apps/modules/task-management/src",
  "tags": ["scope:task-management", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/frontend/apps/modules/task-management",
        "index": "frontend/apps/modules/task-management/src/index.html",
        "main": "frontend/apps/modules/task-management/src/main.ts",
        "tsConfig": "frontend/apps/modules/task-management/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "frontend/apps/modules/task-management/public"
          }
        ],
        "styles": ["frontend/apps/modules/task-management/src/styles.css"],
        "customWebpackConfig": {
          "path": "frontend/apps/modules/task-management/webpack.config.ts"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "frontend/apps/modules/task-management/webpack.prod.config.ts"
          }
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "options": {
        "port": 4205,
        "publicHost": "http://localhost:4205",
        "headers": {
          "Access-Control-Allow-Origin": "*"
        }
      },
      "configurations": {
        "production": {
          "buildTarget": "task-management:build:production"
        },
        "development": {
          "buildTarget": "task-management:build:development"
        }
      },
      "defaultConfiguration": "development",
      "dependsOn": ["client:serve"]
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "task-management:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../../coverage/frontend/apps/modules/task-management"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "task-management:build",
        "port": 4205,
        "watch": false
      },
      "configurations": {
        "development": {
          "buildTarget": "task-management:build:development"
        },
        "production": {
          "buildTarget": "task-management:build:production"
        }
      }
    }
  }
}
