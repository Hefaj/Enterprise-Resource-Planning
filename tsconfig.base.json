{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "baseUrl": ".",
    "paths": {
      "@erp/catalog/Routes": ["frontend/apps/modules/catalog/src/app/remote-entry/entry.routes.ts"],
      "@erp/catalog/MenuDefinition": ["frontend/apps/modules/catalog/src/app/remote-entry/entry.menu.ts"],
      "@erp/inventory/Routes": ["frontend/apps/modules/inventory/src/app/remote-entry/entry.routes.ts"],
      "@erp/inventory/MenuDefinition": ["frontend/apps/modules/inventory/src/app/remote-entry/entry.menu.ts"],
      "@erp/sales/Routes": ["frontend/apps/modules/sales/src/app/remote-entry/entry.routes.ts"],
      "@erp/sales/MenuDefinition": ["frontend/apps/modules/sales/src/app/remote-entry/entry.menu.ts"],
      "@erp/shared/ui": ["frontend/libs/shared/ui/src/index.ts"],
      "@erp/shared/auth": ["frontend/libs/shared/auth/src/index.ts"],
      "@erp/shared/data-access": ["frontend/libs/shared/data-access/src/index.ts"],
      "@erp/client/ui": ["frontend/libs/client/ui/src/index.ts"],
      "@erp/client/feature": ["frontend/libs/client/feature/src/index.ts"],
      "@erp/client/contract": ["frontend/libs/client/contract/src/index.ts"],
      "@erp/client/utils": ["frontend/libs/client/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
