{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": true,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "catalog/Routes": ["frontend/apps/modules/catalog/src/app/remote-entry/entry.routes.ts"],
      "inventory/Routes": ["frontend/apps/modules/inventory/src/app/remote-entry/entry.routes.ts"],
      "sales/Routes": ["frontend/apps/modules/sales/src/app/remote-entry/entry.routes.ts"],
      "@erp/shared-ui": ["frontend/libs/shared-ui/src/index.ts"],
      "@erp/auth": ["frontend/libs/auth/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
